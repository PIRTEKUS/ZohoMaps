# =============================================================================
# ZohoMap Configuration File
#
# SECURITY NOTE:
# This file should contain NON-SECRET configuration values ONLY.
# All secrets must be stored as environment variables in the systemd service
# file by running: sudo ./setup_secrets.sh
#
# Secrets that MUST be in environment variables (NOT here):
#   ZOHO_CLIENT_ID         → Zoho OAuth Client ID
#   ZOHO_CLIENT_SECRET     → Zoho OAuth Client Secret
#   GOOGLE_MAPS_API_KEY    → Google Maps API Key
#   APP_SECRET_KEY         → Flask session signing key
#   DATABASE_URI           → Full DB connection string (if it has a password)
#   TOKEN_ENCRYPTION_KEY   → Auto-generated by setup_secrets.sh / harden_server.sh
#
# Values below are safe to store here because they are not secrets.
# =============================================================================

[ZOHO]
# Comma-separated list of allowed callback URIs (e.g. domain + IP for testing).
# The server automatically picks the one matching the incoming request.
redirect_uri = https://yourdomain.com/callback
# Zoho OAuth server URL for your region
accounts_url = https://accounts.zoho.com
# Zoho CRM API base URL for your region
api_url = https://www.zohoapis.com

[GOOGLE]
# Leave blank — set GOOGLE_MAPS_API_KEY as an environment variable instead.
maps_api_key =

[APP]
# Leave blank — set APP_SECRET_KEY as an environment variable instead.
secret_key =
# Leave blank — set DATABASE_URI as an environment variable instead.
# For local dev without env vars: sqlite:///database.db
database_uri =
