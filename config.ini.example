[ZOHO]
client_id = YOUR_ZOHO_CLIENT_ID
client_secret = YOUR_ZOHO_CLIENT_SECRET
# Comma-separated list of allowed callback URIs (e.g. IP + DNS). The server auto-picks the matching one.
redirect_uri = http://localhost:5000/callback
# Example: https://accounts.zoho.com
accounts_url = https://accounts.zoho.com
# Example: https://www.zohoapis.com
api_url = https://www.zohoapis.com

[GOOGLE]
maps_api_key = YOUR_GOOGLE_MAPS_API_KEY

[APP]
# REQUIRED: Generate a random key with: python3 -c "import secrets; print(secrets.token_hex(32))"
# The app will refuse to start if this is left as the placeholder or is blank.
secret_key = REPLACE_WITH_RANDOM_KEY_SEE_COMMENT_ABOVE
# SQLite (local dev): sqlite:///database.db
# PostgreSQL (production): postgresql://user:password@localhost/zohomap
database_uri = sqlite:///database.db
